{
    "name": "hanzo-hello-world",
    "displayName": "Hanzo Hello World",
    "description": "A simple hello world extension for Hanzo",
    "version": "0.0.1",
    "publisher": "hanzo",
    "engines": {
        "vscode": "^1.94.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onCommand:hanzo-hello-world.helloWorld"
