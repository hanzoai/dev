#!/usr/bin/env bash
# Hanzod - Hanzo Daemon Manager
# Manages background processes, model caching, and session persistence

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'

# Configuration
HANZOD_HOME="${HANZOD_HOME:-$HOME/.hanzod}"
HANZOD_PID_FILE="$HANZOD_HOME/hanzod.pid"
HANZOD_LOG_FILE="$HANZOD_HOME/hanzod.log"
HANZOD_CONFIG="$HANZOD_HOME/config.toml"
HANZOD_SOCKET="$HANZOD_HOME/hanzod.sock"
HANZOD_MODEL_CACHE="$HANZOD_HOME/models"
HANZOD_SESSION_DIR="$HANZOD_HOME/sessions"
HANZOD_STATE_FILE="$HANZOD_HOME/state.json"

# Engine configuration
ENGINE_DIR="${HANZO_ENGINE_DIR:-$HOME/work/hanzo/engine}"
ENGINE_PORT="${HANZO_ENGINE_PORT:-36900}"
NODE_API_PORT="${HANZO_NODE_PORT:-3690}"
P2P_PORT="${HANZO_P2P_PORT:-3691}"

# Model configuration
DEFAULT_MODEL="${HANZO_MODEL:-qwen2.5:7b}"
PRELOAD_MODELS="${HANZO_PRELOAD_MODELS:-qwen2.5:7b,llama3.2:1b}"
MODEL_TIMEOUT="${HANZO_MODEL_TIMEOUT:-300}" # 5 minutes to load models

# Initialize hanzod home directory
init_hanzod_home() {
    if [ ! -d "$HANZOD_HOME" ]; then
        echo -e "${BLUE}Initializing hanzod home at $HANZOD_HOME${NC}"
        mkdir -p "$HANZOD_HOME"
        mkdir -p "$HANZOD_MODEL_CACHE"
        mkdir -p "$HANZOD_SESSION_DIR"
        
        # Create default config
        cat > "$HANZOD_CONFIG" << EOF
# Hanzod Configuration
[daemon]
auto_start = true
background = true
log_level = "info"
max_workers = 4

[engine]
type = "native"  # native, ollama, openai, claude
engine_dir = "$ENGINE_DIR"
engine_port = $ENGINE_PORT
fallback_providers = ["ollama", "openai", "claude"]

[models]
default = "$DEFAULT_MODEL"
preload = ["$DEFAULT_MODEL"]
cache_dir = "$HANZOD_MODEL_CACHE"
auto_download = true

[api]
node_port = $NODE_API_PORT
p2p_port = $P2P_PORT
enable_mcp = true

[session]
persist = true
max_sessions = 10
session_timeout = 3600
EOF
        echo -e "${GREEN}✓ Initialized hanzod home${NC}"
    fi
}

# Check if hanzod is running
is_running() {
    if [ -f "$HANZOD_PID_FILE" ]; then
        local pid=$(cat "$HANZOD_PID_FILE")
        if ps -p "$pid" > /dev/null 2>&1; then
            return 0
        else
            # Stale PID file
            rm -f "$HANZOD_PID_FILE"
        fi
    fi
    return 1
}

# Get daemon status
get_status() {
    if [ -f "$HANZOD_STATE_FILE" ]; then
        cat "$HANZOD_STATE_FILE"
    else
        echo "{}"
    fi
}

# Update daemon state
update_state() {
    local key=$1
    local value=$2
    local timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    
    if [ ! -f "$HANZOD_STATE_FILE" ]; then
        echo "{}" > "$HANZOD_STATE_FILE"
    fi
    
    # Update state using Python for JSON manipulation
    python3 << EOF
import json
import sys

with open("$HANZOD_STATE_FILE", "r") as f:
    state = json.load(f)

state["$key"] = "$value"
state["last_updated"] = "$timestamp"

with open("$HANZOD_STATE_FILE", "w") as f:
    json.dump(state, f, indent=2)
EOF
}

# Start native engine
start_native_engine() {
    echo -e "${BLUE}Starting native Hanzo Engine...${NC}"
    
    if lsof -Pi :$ENGINE_PORT -sTCP:LISTEN -t >/dev/null 2>&1; then
        echo -e "${GREEN}✓ Engine already running on port $ENGINE_PORT${NC}"
        return 0
    fi
    
    # Find engine binary
    local engine_bin=""
    for path in \
        "$ENGINE_DIR/target/release/mistralrs-server" \
        "$ENGINE_DIR/target/release/hanzo-engine" \
        "/usr/local/bin/hanzo-engine"; do
        if [ -f "$path" ]; then
            engine_bin="$path"
            break
        fi
    done
    
    if [ -z "$engine_bin" ]; then
        echo -e "${YELLOW}Native engine not found, falling back to Ollama${NC}"
        return 1
    fi
    
    echo -e "${BLUE}Starting engine: $engine_bin${NC}"
    nohup $engine_bin \
        --port $ENGINE_PORT \
        --model-id "Qwen/Qwen2.5-7B-Instruct" \
        --arch qwen2 \
        --device metal \
        --from-huggingface \
        >> "$HANZOD_LOG_FILE" 2>&1 &
    
    local engine_pid=$!
    echo $engine_pid > "$HANZOD_HOME/engine.pid"
    
    # Wait for engine to be ready
    for i in {1..30}; do
        if lsof -Pi :$ENGINE_PORT -sTCP:LISTEN -t >/dev/null 2>&1; then
            echo -e "${GREEN}✓ Native engine started (PID: $engine_pid)${NC}"
            update_state "engine" "native"
            update_state "engine_pid" "$engine_pid"
            return 0
        fi
        sleep 1
    done
    
    echo -e "${RED}Failed to start native engine${NC}"
    return 1
}

# Start Ollama
start_ollama() {
    echo -e "${BLUE}Starting Ollama...${NC}"
    
    if lsof -Pi :11434 -sTCP:LISTEN -t >/dev/null 2>&1; then
        echo -e "${GREEN}✓ Ollama already running${NC}"
        return 0
    fi
    
    nohup ollama serve >> "$HANZOD_LOG_FILE" 2>&1 &
    local ollama_pid=$!
    echo $ollama_pid > "$HANZOD_HOME/ollama.pid"
    
    # Wait for Ollama to be ready
    for i in {1..10}; do
        if lsof -Pi :11434 -sTCP:LISTEN -t >/dev/null 2>&1; then
            echo -e "${GREEN}✓ Ollama started (PID: $ollama_pid)${NC}"
            update_state "ollama" "running"
            update_state "ollama_pid" "$ollama_pid"
            return 0
        fi
        sleep 1
    done
    
    echo -e "${RED}Failed to start Ollama${NC}"
    return 1
}

# Preload models
preload_models() {
    echo -e "${BLUE}Preloading models...${NC}"
    
    # Check which provider is available
    local provider=""
    if lsof -Pi :$ENGINE_PORT -sTCP:LISTEN -t >/dev/null 2>&1; then
        provider="native"
    elif lsof -Pi :11434 -sTCP:LISTEN -t >/dev/null 2>&1; then
        provider="ollama"
    else
        echo -e "${YELLOW}No provider available for model preloading${NC}"
        return 1
    fi
    
    if [ "$provider" = "ollama" ]; then
        # Preload models in Ollama
        IFS=',' read -ra MODELS <<< "$PRELOAD_MODELS"
        for model in "${MODELS[@]}"; do
            model=$(echo "$model" | tr -d ' ')
            echo -e "${BLUE}Loading model: $model${NC}"
            
            # Check if model exists
            if ! ollama list | grep -q "$model"; then
                echo -e "${YELLOW}Pulling model $model...${NC}"
                ollama pull "$model" >> "$HANZOD_LOG_FILE" 2>&1
            fi
            
            # Warm up the model by running a simple query
            echo "test" | ollama run "$model" --verbose=false > /dev/null 2>&1 &
            local warmup_pid=$!
            
            # Wait for warmup with timeout
            timeout 30 wait $warmup_pid 2>/dev/null || true
            
            echo -e "${GREEN}✓ Model $model loaded${NC}"
            update_state "model_${model//[:.-]/_}" "loaded"
        done
    elif [ "$provider" = "native" ]; then
        echo -e "${BLUE}Native engine handles model loading automatically${NC}"
        update_state "models" "native_managed"
    fi
}

# Create session
create_session() {
    local session_id="${1:-$(uuidgen 2>/dev/null || echo "session_$(date +%s)")}"
    local session_dir="$HANZOD_SESSION_DIR/$session_id"
    
    mkdir -p "$session_dir"
    
    cat > "$session_dir/config.json" << EOF
{
    "id": "$session_id",
    "created": "$(date -u +"%Y-%m-%dT%H:%M:%SZ")",
    "model": "$DEFAULT_MODEL",
    "provider": "$(get_current_provider)",
    "pid": $$,
    "status": "active"
}
EOF
    
    echo "$session_id"
}

# Get current provider
get_current_provider() {
    if lsof -Pi :$ENGINE_PORT -sTCP:LISTEN -t >/dev/null 2>&1; then
        echo "native"
    elif lsof -Pi :11434 -sTCP:LISTEN -t >/dev/null 2>&1; then
        echo "ollama"
    else
        echo "none"
    fi
}

# Start hanzod daemon
start_daemon() {
    if is_running; then
        echo -e "${YELLOW}Hanzod is already running (PID: $(cat $HANZOD_PID_FILE))${NC}"
        return 0
    fi
    
    echo -e "${CYAN}╔════════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║                    Starting Hanzod Daemon                     ║${NC}"
    echo -e "${CYAN}╚════════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    
    init_hanzod_home
    
    # Start daemon process
    (
        echo $$ > "$HANZOD_PID_FILE"
        echo -e "${BLUE}Hanzod starting (PID: $$)${NC}"
        
        # Trap signals for cleanup
        trap 'cleanup_daemon' EXIT INT TERM
        
        # Start services
        if ! start_native_engine; then
            start_ollama
        fi
        
        # Preload models
        preload_models
        
        # Update state
        update_state "daemon" "running"
        update_state "pid" "$$"
        update_state "started" "$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
        
        echo -e "${GREEN}✓ Hanzod daemon started successfully${NC}"
        echo -e "${BLUE}Logs: $HANZOD_LOG_FILE${NC}"
        echo -e "${BLUE}State: $HANZOD_STATE_FILE${NC}"
        
        # Keep daemon running
        while true; do
            # Health check
            if [ -f "$HANZOD_PID_FILE" ]; then
                sleep 10
            else
                break
            fi
        done
    ) >> "$HANZOD_LOG_FILE" 2>&1 &
    
    local daemon_pid=$!
    echo $daemon_pid > "$HANZOD_PID_FILE"
    
    # Wait a moment for daemon to initialize
    sleep 2
    
    if is_running; then
        echo -e "${GREEN}✓ Hanzod daemon started (PID: $daemon_pid)${NC}"
        echo -e "${BLUE}Provider: $(get_current_provider)${NC}"
    else
        echo -e "${RED}Failed to start hanzod daemon${NC}"
        return 1
    fi
}

# Stop daemon
stop_daemon() {
    if ! is_running; then
        echo -e "${YELLOW}Hanzod is not running${NC}"
        return 0
    fi
    
    local pid=$(cat "$HANZOD_PID_FILE")
    echo -e "${BLUE}Stopping hanzod daemon (PID: $pid)...${NC}"
    
    # Stop child processes
    if [ -f "$HANZOD_HOME/engine.pid" ]; then
        kill $(cat "$HANZOD_HOME/engine.pid") 2>/dev/null || true
        rm -f "$HANZOD_HOME/engine.pid"
    fi
    
    if [ -f "$HANZOD_HOME/ollama.pid" ]; then
        kill $(cat "$HANZOD_HOME/ollama.pid") 2>/dev/null || true
        rm -f "$HANZOD_HOME/ollama.pid"
    fi
    
    # Stop main daemon
    kill $pid 2>/dev/null || true
    rm -f "$HANZOD_PID_FILE"
    
    update_state "daemon" "stopped"
    update_state "stopped" "$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
    
    echo -e "${GREEN}✓ Hanzod daemon stopped${NC}"
}

# Cleanup daemon
cleanup_daemon() {
    echo -e "\n${BLUE}Cleaning up hanzod...${NC}"
    
    # Stop services
    if [ -f "$HANZOD_HOME/engine.pid" ]; then
        kill $(cat "$HANZOD_HOME/engine.pid") 2>/dev/null || true
        rm -f "$HANZOD_HOME/engine.pid"
    fi
    
    if [ -f "$HANZOD_HOME/ollama.pid" ]; then
        kill $(cat "$HANZOD_HOME/ollama.pid") 2>/dev/null || true
        rm -f "$HANZOD_HOME/ollama.pid"
    fi
    
    rm -f "$HANZOD_PID_FILE"
    update_state "daemon" "stopped"
}

# Status command
show_status() {
    echo -e "${CYAN}╔════════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║                      Hanzod Status                            ║${NC}"
    echo -e "${CYAN}╚════════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    
    # Daemon status
    if is_running; then
        echo -e "${GREEN}✓ Daemon: Running (PID: $(cat $HANZOD_PID_FILE))${NC}"
    else
        echo -e "${RED}✗ Daemon: Not running${NC}"
    fi
    
    # Provider status
    echo -e "\n${BLUE}Providers:${NC}"
    if lsof -Pi :$ENGINE_PORT -sTCP:LISTEN -t >/dev/null 2>&1; then
        echo -e "${GREEN}  ✓ Native Engine (port $ENGINE_PORT)${NC}"
    else
        echo -e "${YELLOW}  ○ Native Engine${NC}"
    fi
    
    if lsof -Pi :11434 -sTCP:LISTEN -t >/dev/null 2>&1; then
        echo -e "${GREEN}  ✓ Ollama (port 11434)${NC}"
    else
        echo -e "${YELLOW}  ○ Ollama${NC}"
    fi
    
    if lsof -Pi :$NODE_API_PORT -sTCP:LISTEN -t >/dev/null 2>&1; then
        echo -e "${GREEN}  ✓ Node API (port $NODE_API_PORT)${NC}"
    else
        echo -e "${YELLOW}  ○ Node API${NC}"
    fi
    
    # Model status
    echo -e "\n${BLUE}Models:${NC}"
    if lsof -Pi :11434 -sTCP:LISTEN -t >/dev/null 2>&1; then
        local models=$(ollama list 2>/dev/null | grep -c "qwen" || echo "0")
        echo -e "  Qwen models loaded: ${GREEN}$models${NC}"
    fi
    
    # Session status
    echo -e "\n${BLUE}Sessions:${NC}"
    if [ -d "$HANZOD_SESSION_DIR" ]; then
        local sessions=$(ls -1 "$HANZOD_SESSION_DIR" 2>/dev/null | wc -l)
        echo -e "  Active sessions: ${GREEN}$sessions${NC}"
    fi
    
    # State file
    if [ -f "$HANZOD_STATE_FILE" ]; then
        echo -e "\n${BLUE}State:${NC}"
        jq -r 'to_entries | map("  \(.key): \(.value)") | .[]' "$HANZOD_STATE_FILE" 2>/dev/null || cat "$HANZOD_STATE_FILE"
    fi
}

# Connect to daemon for interactive session
connect_session() {
    if ! is_running; then
        echo -e "${YELLOW}Starting hanzod daemon first...${NC}"
        start_daemon
    fi
    
    local session_id=$(create_session)
    echo -e "${GREEN}Connected to hanzod (session: $session_id)${NC}"
    echo -e "${BLUE}Provider: $(get_current_provider)${NC}"
    
    # Export session for child processes
    export HANZOD_SESSION_ID="$session_id"
    export HANZOD_PROVIDER="$(get_current_provider)"
    
    # Return session info
    echo "$session_id"
}

# Main command handler
main() {
    local command="${1:-help}"
    shift || true
    
    case "$command" in
        start)
            start_daemon
            ;;
            
        stop)
            stop_daemon
            ;;
            
        restart)
            stop_daemon
            sleep 2
            start_daemon
            ;;
            
        status)
            show_status
            ;;
            
        connect)
            connect_session
            ;;
            
        logs)
            if [ -f "$HANZOD_LOG_FILE" ]; then
                tail -f "$HANZOD_LOG_FILE"
            else
                echo -e "${YELLOW}No log file found${NC}"
            fi
            ;;
            
        clean)
            echo -e "${YELLOW}Cleaning hanzod data...${NC}"
            stop_daemon
            rm -rf "$HANZOD_HOME"
            echo -e "${GREEN}✓ Cleaned hanzod data${NC}"
            ;;
            
        preload)
            if is_running; then
                preload_models
            else
                echo -e "${YELLOW}Hanzod not running. Start it first.${NC}"
            fi
            ;;
            
        session)
            local subcmd="${1:-list}"
            case "$subcmd" in
                list)
                    if [ -d "$HANZOD_SESSION_DIR" ]; then
                        ls -la "$HANZOD_SESSION_DIR"
                    fi
                    ;;
                new)
                    connect_session
                    ;;
                *)
                    echo "Usage: hanzod session [list|new]"
                    ;;
            esac
            ;;
            
        help|*)
            echo "Hanzod - Hanzo Daemon Manager"
            echo ""
            echo "Usage: hanzod <command> [options]"
            echo ""
            echo "Commands:"
            echo "  start       Start the hanzod daemon"
            echo "  stop        Stop the hanzod daemon"
            echo "  restart     Restart the daemon"
            echo "  status      Show daemon and service status"
            echo "  connect     Connect to daemon (creates session)"
            echo "  logs        Follow daemon logs"
            echo "  clean       Clean all hanzod data"
            echo "  preload     Preload configured models"
            echo "  session     Manage sessions (list|new)"
            echo "  help        Show this help message"
            echo ""
            echo "Environment Variables:"
            echo "  HANZOD_HOME         Daemon home directory (default: ~/.hanzod)"
            echo "  HANZO_ENGINE_DIR    Engine directory"
            echo "  HANZO_ENGINE_PORT   Engine port (default: 36900)"
            echo "  HANZO_MODEL         Default model (default: qwen2.5:7b)"
            echo "  HANZO_PRELOAD_MODELS Comma-separated models to preload"
            echo ""
            echo "Files:"
            echo "  ~/.hanzod/          Daemon home directory"
            echo "  ~/.hanzod/config.toml Configuration file"
            echo "  ~/.hanzod/state.json Current state"
            echo "  ~/.hanzod/sessions/  Active sessions"
            echo "  ~/.hanzod/models/    Model cache"
            ;;
    esac
}

# Run main function
main "$@"